{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    "rules/lifecycle.md",
    "rules/backend-spec.md",
    "rules/agents-guide.md"
  ],
  "mcp": {
    "gopls": {
      "type": "local",
      "command": ["gopls", "mcp"],
      "enabled": true
    },
    "serena": {
      "type": "local",
      "command": ["serena", "start-mcp-server", "--context", "opencode", "--project-from-cwd"],
      "enabled": false
    }
  }
}
